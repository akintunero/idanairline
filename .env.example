# Idan Airlines CTF — Hybrid Validation Model
# Copy to .env and set stealth key values for your deployment.
# Docker Compose reads .env automatically when present.

# Auth (user-api)
JWT_SECRET=super_secret_idan_key

# A01 — Broken Object Level Authorization (booking-api)
CTF_FLAG_A01_BOLA=

# A02 — Broken Authentication (user-api)
CTF_FLAG_A02_BROKEN_AUTH=

# A03 — Mass Assignment (user-api)
CTF_FLAG_A03_MASS_ASSIGNMENT=

# A05 — SQL Injection (payment-api)
CTF_FLAG_A05_SQLI=

# A07 — SSRF (payment-api)
CTF_FLAG_A07_SSRF=

# A06 — Race Condition (booking-api)
CTF_FLAG_A06_RACE=

# A09 — Shadow API (booking-api)
CTF_FLAG_A09_SHADOW_API=

# A10 — Fail-Open Logic (booking-api)
CTF_FLAG_A10_FAIL_OPEN=
